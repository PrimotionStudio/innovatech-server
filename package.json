{
  "name": "innovatech-server",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "prisma migrate deploy && node dist/src/index.js",
    "db": "bunx prisma migrate dev --name init && bunx prisma generate && bunx prisma db push",
    "postinstall": "prisma generate"
  },
  "dependencies": {
    "@hono/node-server": "^2.0.3",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "bcrypt": "^6.0.0",
    "bcryptjs": "^3.0.3",
    "hono": "^4.12.19",
    "hono-rate-limiter": "^0.5.3",
    "jose": "^6.2.3",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/bcryptjs": "^3.0.0",
    "@types/bun": "latest",
    "@types/node": "^20.11.17",
    "prisma": "^7.8.0",
    "tsx": "^4.7.1",
    "typescript": "^5.8.3"
  }
}
